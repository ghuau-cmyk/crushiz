# =====================================================================
#  MODÈLE de configuration — NE PAS mettre de vraies valeurs ici.
#  Le vrai .env vit UNIQUEMENT sur le serveur de production, et n'est
#  jamais committé (cf. .gitignore). Règle d'or n°1.
# =====================================================================

# Clé AES-256 (32 octets en base64) :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CLE_CHIFFREMENT_V1=

# Pepper HMAC (>= 32 octets en base64), généré de la même façon :
PEPPER_HMAC=

# Connexion PostgreSQL (base compat, user app, en local sur le serveur) :
DATABASE_URL=postgres://app:MOT_DE_PASSE@127.0.0.1:5432/compat

# Port d'écoute interne (le reverse proxy aaPanel pointe dessus) :
PORT=3000
